{
	"name": "maply",
	"version": "0.2.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "husky",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json && pnpm check:deps",
		"check:deps": "depcruise --validate .dependency-cruiser.cjs app packages",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "vitest run tests/",
		"test:io": "pnpm --filter @maply/io test",
		"test:model": "pnpm --filter @maply/model test",
		"lint": "eslint --ignore-pattern \"src/lib/components/ui/**\" --fix .",
		"fmt": "oxfmt && prettier --log-level warn --write ."
	},
	"dependencies": {
		"@maply/io": "workspace:*",
		"effect": "catalog:"
	},
	"devDependencies": {
		"@eslint/js": "catalog:",
		"@fontsource-variable/geist-mono": "catalog:",
		"@fontsource-variable/inter": "catalog:",
		"@internationalized/date": "catalog:",
		"@sveltejs/adapter-static": "catalog:",
		"@sveltejs/kit": "catalog:",
		"@sveltejs/vite-plugin-svelte": "catalog:",
		"@tailwindcss/typography": "catalog:",
		"@tailwindcss/vite": "catalog:",
		"@types/node": "catalog:",
		"bits-ui": "catalog:",
		"clsx": "catalog:",
		"dependency-cruiser": "catalog:",
		"eslint": "catalog:",
		"eslint-config-prettier": "catalog:",
		"eslint-plugin-svelte": "catalog:",
		"globals": "catalog:",
		"husky": "catalog:",
		"lint-staged": "catalog:",
		"oxfmt": "catalog:",
		"oxlint": "catalog:",
		"phosphor-icons": "catalog:",
		"phosphor-svelte": "catalog:",
		"prettier": "catalog:",
		"prettier-plugin-svelte": "catalog:",
		"prettier-plugin-tailwindcss": "catalog:",
		"shadcn-svelte": "catalog:",
		"svelte": "catalog:",
		"svelte-check": "catalog:",
		"tailwind-merge": "catalog:",
		"tailwind-variants": "catalog:",
		"tailwindcss": "catalog:",
		"tw-animate-css": "catalog:",
		"typescript": "catalog:",
		"typescript-eslint": "catalog:",
		"vite": "catalog:",
		"vitest": "catalog:"
	},
	"lint-staged": {
		"*.{js,ts,svelte,json,css}": [
			"oxfmt",
			"prettier --write",
			"eslint --ignore-pattern \"src/lib/components/ui/**\" --fix"
		]
	},
	"engines": {
		"node": "^24.15.0"
	},
	"packageManager": "pnpm@11.9.0"
}
